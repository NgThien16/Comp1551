@{
}
<!DOCTYPE html>
    <html>
    <head>
        <title>WeeklyTypedLogin</title>
    </head>
    <body>
    @using (Html.BeginForm("LoginPost", "Account", FormMethod.Post))
        {
            <div>
            Username:@Html.TextBox("username")
            </div>
            <div>
            Password:@Html.Password("password")
            </div>
            <div>
            <input type="submit" value="Login"/>
            </div>
        }
    </body>
    </html>
