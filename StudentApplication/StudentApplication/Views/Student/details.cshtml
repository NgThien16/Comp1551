@{
    ViewData["Title"] = "Students";
}
<h2>Student Details</h2>
<div class="card">
    <div class="card-body">
        <h5 class="card-title
">
            @Model.FullName
        </h5>   
        <p class="card-text"><strong>Email:</strong> @Model.Email</p>
        <p class="card-text"><strong>Date of Birth:</strong> @Model.DateOfBirth.ToShortDateString()</p>
        <a href="@Url.Action("Index")" class="btn btn-primary">Back to List</a>
    </div>
</div>

