@model IEnumerable<StudentApplication.Models.Student>
<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


@{
    ViewData["Title"] = "Students";
}
<h2>Students</h2>
<a href="/Student/Create" class="btn btn-outline-primary btn-sm">+ Add Student</a>
 <table class="table table-striped">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>DOB</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr class="alert-dark">
                <td>@student.FullName</td>
                <td>@student.Email</td>
                <td>@student.DateOfBirth.ToShortDateString()</td>
                <td>
                    <a href="/Student/Details/@student.Id" class="btn btn-primary btn-sm">View</a> |
                    <a href="/Student/Edit/@student.Id" class="btn btn-outline-success btn-sm">Edit</a> |
                    <a href="/Student/Delete/@student.Id" class="btn btn-warning btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>